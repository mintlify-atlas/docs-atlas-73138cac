  "keyFeatures": [
    "Visual query builder with no-SQL-required interface",
    "Native SQL editor with autocomplete and syntax highlighting",
    "Interactive dashboards with filters, drill-through, and subscriptions",
    "Data modeling with models, metrics, and segments",
    "18+ database connectors including PostgreSQL, MySQL, BigQuery, Snowflake",
    "Embedding SDK for React with customizable components",
    "Full-app and modular embedding with SSO",
    "AI-powered SQL generation with Metabot",
    "Row and column-level permissions",
    "Automated dashboard subscriptions and alerts",
    "REST API for programmatic access",
    "Multi-tenant support with sandboxing"
  ],
  "publicApiSurface": [
    "/api/database - Database connections and metadata",
    "/api/card - Saved questions and queries",
    "/api/dashboard - Dashboard management",
    "/api/dataset - Execute queries and retrieve data",
    "/api/collection - Organize content in collections",
    "/api/user - User management",
    "/api/session - Authentication and sessions",
    "/api/permissions - Access control",
    "/api/action - HTTP and database actions",
    "/api/embedding - Embedding tokens and parameters",
    "/api/public - Public sharing endpoints",
    "/api/field - Field metadata and configuration",
    "/api/table - Table metadata",
    "/api/segment - Saved filters",
    "/api/metric - Saved metrics",
    "@metabase/embedding-sdk-react - React SDK for embedding",
    "MetabaseProvider - SDK context provider",
    "InteractiveQuestion - Embeddable question component",
    "InteractiveDashboard - Embeddable dashboard component",
    "StaticQuestion - Read-only question component",
    "StaticDashboard - Read-only dashboard component"
  ]
